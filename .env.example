# Google Apps Script web app URL (POST JSON). Forwarded by /api/google-sheets-proxy.
# Payload: { payload_format_version: 2, participant_id, responses, response_rows } — see lib/experimentWebhook.ts and scripts/google-apps-script-doPost.example.gs.
# Set on the server that runs `next start` (proxy reads it at runtime). Do not leave empty in production.
NEXT_PUBLIC_WEBHOOK_URL=

# TwitterAPI.io — optional. If unset, curated mock tweets are used.
# https://twitterapi.io — key is sent only from the server (this route: /api/twitter/expert).
TWITTERAPI_IO_KEY=
