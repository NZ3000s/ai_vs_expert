# Google Apps Script web app URL (POST JSON). Forwarded by /api/google-sheets-proxy.
# Payload shape: { responses: SheetResponseRow[] } — each row is a 12-element array (column order in SHEET_ROW_KEYS).
NEXT_PUBLIC_WEBHOOK_URL=

# TwitterAPI.io — optional. If unset, curated mock tweets are used.
# https://twitterapi.io — key is sent only from the server (this route: /api/twitter/expert).
TWITTERAPI_IO_KEY=
