# --- Main experiment (this app, e.g. npm run dev on port 3000) ---
# Google Apps Script web app URL (POST JSON). Forwarded by /api/google-sheets-proxy.
# Payload: { payload_format_version: 2, participant_id, responses, response_rows } — see lib/experimentWebhook.ts.
# Set on the server that runs `next start` (proxy reads it at runtime). Do not leave empty in production.
# Control group uses a separate app + env: see control_experiment/.env.example (CONTROL_SHEETS_WEBHOOK_URL).
NEXT_PUBLIC_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbwmmtAnEA_1oWcGqVEG0Ng-8F9ODQE1zh67uSGZtyQ7PUHIAc4U3h2Datf-UIkK5Hq6mg/exec

# TwitterAPI.io — optional. If unset, curated mock tweets are used.
# https://twitterapi.io — key is sent only from the server (this route: /api/twitter/expert).
TWITTERAPI_IO_KEY=

# Temporary: allow multiple completions per browser while configuring. Remove or set false before production.
# NEXT_PUBLIC_EXPERIMENT_ALLOW_REPEAT=true
